            "hash": "0593ad4e3b105db0fe2b156938ea2ef859415840c8b7118b2ab1a183156b9f5b"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.2.69/CLIProxyAPI_7.2.69_windows_aarch64.zip",
            "hash": "20a9f781163e9f63a6ff56e6777c97a8780d9fca36b964856aa467fba12f388a"
        }
    },
    "pre_install": [
        "if (-not (Test-Path -Path \"$persist_dir\\config.yaml\")) {",
        "    Copy-Item -Path \"$dir\\config.example.yaml\" -Destination \"$dir\\config.yaml\"",
        "}"
    ],
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
